# Copy this file to .env for local development (do NOT commit the real .env).
# On Streamlit Community Cloud, set this instead under App Settings -> Secrets:
#   GEMINI_API_KEY = "your_key_here"

GEMINI_API_KEY=your_gemini_api_key_here

# Get a free Gemini API key at: https://aistudio.google.com/apikey
# The app works fully even without this key -- every AI feature has a
# rule-based fallback (see src/ai_analyzer.py).
